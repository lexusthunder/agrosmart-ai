# AgroSmart AI - Environment Variables
APP_NAME="AgroSmart AI"
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite:///./data/agrosmart.db
# Pentru PostgreSQL in productie:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/agrosmart

# Securitate
SECRET_KEY=schimba-in-productie-cu-o-cheie-aleatoare-foarte-lunga-de-minim-32-caractere
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_PORT=7860
DASHBOARD_API_URL=http://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:7860,http://localhost:3000

# Praguri decizie (override-uri)
THRESHOLD_HUMIDITY_LOW=30.0
THRESHOLD_HUMIDITY_HIGH=80.0
THRESHOLD_PH_LOW=5.5
THRESHOLD_PH_HIGH=7.5
THRESHOLD_TEMP_LOW=5.0
THRESHOLD_TEMP_HIGH=35.0
